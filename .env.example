# IA-1stEngine SaaS Base
# Copy to .env.local for local development. Never commit real secrets.

APP_NAME=IA-1stEngine SaaS Base
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace_with_local_secret
OAUTH_CLIENT_ID=replace_with_provider_client_id
OAUTH_CLIENT_SECRET=replace_with_provider_client_secret

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=app_db
DATABASE_URL=postgres://app_user:app_password@localhost:5432/app_db

APP_IMAGE=ghcr.io/datavisio-tech/ia-firstengine-base-datavisio
APP_PUBLIC_HOST=app.example.com
COMPOSE_PROJECT_NAME=ia-firstengine-base
